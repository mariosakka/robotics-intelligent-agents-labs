<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.3" snapToGrid="true">
  <code><![CDATA[breed [rabbits rabbit]
breed [zombie-rabbits zombie-rabbit]

turtles-own [
  energy
  strength
]

to setup
  clear-all
  set-default-shape rabbits "rabbit"
  set-default-shape zombie-rabbits "rabbit"
  setup-patches
  setup-rabbits
  reset-ticks
end

to setup-rabbits
  create-rabbits number-rabbits [
    setxy random-xcor random-ycor
    set heading random 360
    set color gray
    set size 1.2
    set energy rabbit-starting-energy
    set strength random-float max-initial-rabbit-strength
  ]
end

to setup-patches
  ask patches [ set pcolor green ]

  if grass-ul? [ zombie-grass-ul ]
  if grass-ur? [ zombie-grass-ur ]
  if grass-ll? [ zombie-grass-ll ]
  if grass-lr? [ zombie-grass-lr ]
end

to zombie-grass-ul
  ask patch (round (min-pxcor / 2)) (round (max-pycor / 2)) [ set pcolor red ]
end

to zombie-grass-ur
  ask patch (round (max-pxcor / 2)) (round (max-pycor / 2)) [ set pcolor red ]
end

to zombie-grass-ll
  ask patch (round (min-pxcor / 2)) (round (min-pycor / 2)) [ set pcolor red ]
end

to zombie-grass-lr
  ask patch (round (max-pxcor / 2)) (round (min-pycor / 2)) [ set pcolor red ]
end

to go
  if not any? turtles [ stop ]
  move-rabbits
  move-zombie-rabbits
  feed-rabbits
  feed-zombie-rabbits
  reproduce-rabbits
  grow-grass
  death
  tick
  wait (1 / simulation-speed)
end

to move-rabbits
  ask rabbits [
    right random 50
    left random 50
    forward 1
    set energy energy - rabbit-loss-move
  ]
end

to move-zombie-rabbits
  ask zombie-rabbits [
    let target one-of rabbits in-radius zombie-vision-radius
    ifelse target != nobody [
      face target
    ] [
      right random 50
      left random 50
    ]
    forward 1
    set energy energy - zombie-rabbit-loss-move
  ]
end

to feed-rabbits
  ask rabbits [
    if pcolor = green [
      set energy energy + rabbit-gain-feed
      set pcolor brown
    ]

    if pcolor = red [
      ;; rabbit becomes a zombie after eating infected grass
      set breed zombie-rabbits
      set color magenta
      set size 1.3
      zombie-mutation
    ]
  ]
end

to feed-zombie-rabbits
  ask zombie-rabbits [
    let prey one-of rabbits-here
    if prey != nobody [
      let rabbit-wins? winner? ([strength] of prey) strength
      ifelse rabbit-wins? [
        die
      ] [
        set energy energy + zombie-rabbit-gain-feed
        let parent-strength strength
        ask prey [
          set breed zombie-rabbits
          set color magenta
          set size 1.3
          set energy zombie-rabbit-starting-energy
          set strength parent-strength
          zombie-mutation
        ]
      ]
    ]
  ]
end

to reproduce-rabbits
  ask rabbits [
    if random 100 < rabbit-reprod-prob [
      set energy energy / 2
      hatch-rabbits 1 [
        set energy [energy] of myself
        set strength [strength] of myself
        rabbit-mutation
        right random 360
        forward 1
      ]
    ]
  ]
end

to grow-grass
  ask patches with [pcolor = brown] [
    if random 100 < grass-regrowth-prob [ set pcolor green ]
  ]
end

to death
  ask turtles with [energy <= 0] [ die ]
end

to rabbit-mutation
  if random 100 < rabbit-mutation-rate [
    set strength strength - rabbit-mutation-ampl + rabbit-mutation-ampl * random-float 2
    if strength < 0 [ set strength 0 ]
  ]
end

to zombie-mutation
  if random 100 < zombie-mutation-rate [
    set strength strength - zombie-mutation-ampl + zombie-mutation-ampl * random-float 2
    if strength < 0 [ set strength 0 ]
  ]
end

;; true = rabbit wins, false = zombie wins
to-report winner? [rabbit-strength zombie-strength]
  let delta-proto rabbit-strength - zombie-strength
  let delta abs delta-proto

  if delta-for-guaranteed-win <= 0 [
    report rabbit-strength >= zombie-strength
  ]

  if delta >= delta-for-guaranteed-win [
    report rabbit-strength > zombie-strength
  ]

  ;; Probabilistic result biased toward the stronger agent.
  ;; If strengths are equal, rabbit has about 50% chance.
  let rabbit-win-prob 0.5 + (delta-proto / delta-for-guaranteed-win) * 0.5
  if rabbit-win-prob < 0 [ set rabbit-win-prob 0 ]
  if rabbit-win-prob > 1 [ set rabbit-win-prob 1 ]
  report random-float 1 < rabbit-win-prob
end
]]></code>
