<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.3" snapToGrid="true">
  <code><![CDATA[breed [humans human]

patches-own [
  wall?
  exit?
  office?
  meeting?
  burning?
  exit-signal
]

humans-own [
  behavior   ;; 0 = stays before emergency, 1 = moves before emergency
]

globals [
  evacuated
  fatalities
  fire-started?
]

to setup
  clear-all
  set evacuated 0
  set fatalities 0
  set fire-started? false
  set-default-shape humans "person"
  load-patches
  place-humans
  reset-ticks
end

to load-patches
  ifelse file-exists? "floor.png" [
    import-pcolors "floor.png"
  ] [
    ifelse file-exists? "floor.bmp" [
      import-pcolors "floor.bmp"
    ] [
      draw-fallback-floor
    ]
  ]
  classify-patches
end

to draw-fallback-floor
  ask patches [ set pcolor [128 128 128] ]
  ask patches with [pxcor = min-pxcor or pxcor = max-pxcor or pycor = min-pycor or pycor = max-pycor] [ set pcolor black ]
  ask patches with [pxcor = 15 or pycor = 15] [ set pcolor black ]
  ask patches with [pxcor = 15 and pycor >= 13 and pycor <= 18] [ set pcolor [128 128 128] ]
  ask patches with [pycor = 15 and pxcor >= 13 and pxcor <= 18] [ set pcolor [128 128 128] ]
  ask patches with [pxcor < 15 and pycor > 15 and not (pxcor = min-pxcor or pycor = max-pycor)] [ set pcolor [64 64 192] ]
  ask patches with [pxcor > 15 and pycor > 15 and not (pxcor = max-pxcor or pycor = max-pycor)] [ set pcolor [64 64 192] ]
  ask patches with [pxcor < 15 and pycor < 15 and not (pxcor = min-pxcor or pycor = min-pycor)] [ set pcolor [160 64 192] ]
  ask patches with [pxcor > 15 and pycor < 15 and not (pxcor = max-pxcor or pycor = min-pycor)] [ set pcolor [64 64 192] ]
  ask patches with [(pxcor = min-pxcor and pycor = 5) or (pxcor = max-pxcor and pycor = 26) or (pycor = min-pycor and pxcor = 24)] [ set pcolor [32 192 64] ]
end

to classify-patches
  ask patches [
    set wall? false
    set exit? false
    set office? false
    set meeting? false
    set burning? false
    set exit-signal 0

    if color-close? pcolor 0 0 0 20 [
      set wall? true
      set pcolor black
    ]
    if color-close? pcolor 32 192 64 40 [
      set exit? true
      set pcolor green
    ]
    if color-close? pcolor 64 64 192 60 [
      set office? true
      set pcolor blue
    ]
    if color-close? pcolor 160 64 192 70 [
      set meeting? true
      set pcolor violet
    ]
    if not wall? and not exit? and not office? and not meeting? [
      set pcolor gray
    ]
  ]
end

to-report color-close? [c r g b tolerance]
  let rgb ifelse-value is-list? c [c] [extract-rgb c]
  report abs (item 0 rgb - r) <= tolerance and
         abs (item 1 rgb - g) <= tolerance and
         abs (item 2 rgb - b) <= tolerance
end

to place-humans
  let valid-patches patches with [not wall? and not exit? and not burning?]
  create-humans number-humans [
    move-to one-of valid-patches
    set heading random 360
    set behavior random 2
    set color white
    set size 1.2
  ]
end

to go
  if not any? humans and not any? patches with [burning?] [ stop ]
  spread-fire
  update-exit-field
  move-humans
  death-humans
  update-plots
  tick
  wait (1 / simulation-speed)
end

to fire-offices
  let possible patches with [office? and not burning?]
  if any? possible [
    ask one-of possible [ ignite ]
    set fire-started? true
  ]
end

to fire-conference
  let possible patches with [meeting? and not burning?]
  if any? possible [
    ask one-of possible [ ignite ]
    set fire-started? true
  ]
end

to ignite
  if not wall? and not exit? [
    set burning? true
    set pcolor red
  ]
end

to spread-fire
  if not fire-started? [ stop ]
  ask patches with [burning?] [
    ask neighbors4 with [not wall? and not exit? and not burning?] [
      if random-float 100 < fire-spread-probability [ ignite ]
    ]
  ]
end

to update-exit-field
  ask patches [ set exit-signal 0 ]
  ask patches with [exit?] [
    ifelse congestion-aware? [
      set exit-signal max list 200 (1000 - exit-congestion-penalty * count humans in-radius 3)
    ] [
      set exit-signal 1000
    ]
  ]

  repeat 18 [
    diffuse exit-signal 0.7
    ask patches with [wall? or burning?] [ set exit-signal 0 ]
    ask patches with [exit?] [
      ifelse congestion-aware? [
        set exit-signal max list 200 (1000 - exit-congestion-penalty * count humans in-radius 3)
      ] [
        set exit-signal 1000
      ]
    ]
  ]
end

to move-humans
  ask humans [
    if [exit?] of patch-here [ evacuate stop ]

    ifelse fire-started? [
      evacuate-move
    ] [
      if behavior = 1 [ random-safe-move ]
    ]
  ]
end

to random-safe-move
  let candidates neighbors4 with [not wall? and not burning?]
  if any? candidates [ move-to one-of candidates ]
end

to evacuate-move
  let candidates neighbors4 with [not wall? and not burning?]
  if any? candidates [
    move-to max-one-of candidates [exit-signal]
  ]
  if [exit?] of patch-here [ evacuate ]
end

to evacuate
  set evacuated evacuated + 1
  die
end

to death-humans
  ask humans with [[burning?] of patch-here] [
    set fatalities fatalities + 1
    die
  ]
end
]]></code>
  <widgets>
    <view x="300" y="25" width="544" height="544" patchSize="16" minPxcor="0" maxPxcor="31" minPycor="0" maxPycor="31" wrappingAllowedX="false" wrappingAllowedY="false" fontSize="10" updateMode="0" frameRate="30.0" showTickCounter="true" tickCounterLabel="ticks"></view>
    <button x="20" y="25" width="70" height="40" display="setup" kind="Observer" forever="false" disableUntilTicks="false">setup</button>
    <button x="100" y="25" width="70" height="40" display="go" kind="Observer" forever="true" disableUntilTicks="false">go</button>
    <button x="20" y="80" width="115" height="40" display="fire-offices" kind="Observer" forever="false" disableUntilTicks="false">fire-offices</button>
    <button x="145" y="80" width="135" height="40" display="fire-conference" kind="Observer" forever="false" disableUntilTicks="false">fire-conference</button>
    <slider x="20" y="140" width="250" height="50" variable="number-humans" display="number-humans" min="0" max="200" default="80" step="1" direction="Horizontal"></slider>
    <slider x="20" y="195" width="250" height="50" variable="fire-spread-probability" display="fire-spread-probability" min="0" max="100" default="12" step="1" direction="Horizontal"></slider>
    <slider x="20" y="250" width="250" height="50" variable="simulation-speed" display="simulation-speed" min="1" max="60" default="20" step="1" direction="Horizontal"></slider>
    <switch x="20" y="315" width="150" height="40" variable="congestion-aware?" display="congestion-aware?" on="true"></switch>
    <slider x="20" y="365" width="250" height="50" variable="exit-congestion-penalty" display="exit-congestion-penalty" min="0" max="100" default="25" step="1" direction="Horizontal"></slider>
    <monitor x="875" y="25" width="120" height="50" display="humans left">count humans</monitor>
    <monitor x="1005" y="25" width="120" height="50" display="evacuated">evacuated</monitor>
    <monitor x="1135" y="25" width="120" height="50" display="fatalities">fatalities</monitor>
    <monitor x="1265" y="25" width="120" height="50" display="fire patches">count patches with [burning?]</monitor>
    <plot x="875" y="100" width="510" height="260" display="Evacuation results" xAxis="ticks" yAxis="people">
      <pen name="evacuated" interval="1" mode="0" color="55">plot evacuated</pen>
      <pen name="fatalities" interval="1" mode="0" color="15">plot fatalities</pen>
      <pen name="inside" interval="1" mode="0" color="0">plot count humans</pen>
    </plot>
  </widgets>
  <info><![CDATA[## WHAT IS IT?

This model simulates an office-floor evacuation during a fire emergency. Humans move through corridors and rooms, avoid walls and fire, and evacuate through emergency exits.

## HOW IT WORKS

The floor is loaded from `floor.png` or `floor.bmp` using `import-pcolors`. Black patches are walls, green patches are emergency exits, blue/violet patches are office or meeting spaces, gray patches are corridors, and red patches are fire.

Before a fire starts, some humans move randomly and some stay still. After a fire starts, humans follow an exit-gradient field toward exits. Fire spreads probabilistically to neighboring patches but cannot pass through walls or emergency exits.

## HOW TO USE IT

Press `setup`, then use either `fire-offices` or `fire-conference` to start the fire. Press `go` to run the simulation.

`number-humans` controls the number of people. `fire-spread-probability` controls how quickly fire spreads. `simulation-speed` controls the visual speed. `congestion-aware?` enables the extra behavior where exits become less attractive when crowded. `exit-congestion-penalty` controls how strongly congestion matters.

## THINGS TO NOTICE

Watch how fire location, spread probability, and congestion affect evacuation and fatalities.
]]></info>
  <turtleShapes></turtleShapes>
  <linkShapes></linkShapes>
</model>
